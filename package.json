{
  "name": "@yanivjs/yaniv-editor",
  "version": "0.1.0",
  "description": "Yaniv Editor — Beautiful Tiptap 3 + Vue 3 rich-text editor appearance with AI support",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.17.0",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./inline": {
      "types": "./dist/inline.d.ts",
      "import": "./dist/inline.esm.js",
      "require": "./dist/inline.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.esm.js",
      "require": "./dist/ai.js"
    },
    "./style.css": "./dist/style.css",
    "./inline.css": "./dist/inline.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "pages:build": "bash scripts/build-pages.sh",
    "pages:preview": "pnpm pages:build && npx serve _site",
    "build:types": "vue-tsc --noEmit -p tsconfig.build.json",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint '{src,examples}/**/*.{css,scss,vue}'",
    "lint:style:fix": "stylelint '{src,examples}/**/*.{css,scss,vue}' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run lint && pnpm run lint:style && pnpm run format:check",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && pnpm publish"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,cjs}": "eslint --fix",
    "*.{css,scss,vue}": "stylelint --fix",
    "*.{json,md,yaml,yml,css,scss,vue,ts,js,mjs,cjs}": "prettier --write"
  },
  "peerDependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-character-count": "^3.0.0",
    "@tiptap/extension-code-block-lowlight": "^3.0.0",
    "@tiptap/extension-color": "^3.0.0",
    "@tiptap/extension-font-family": "^3.0.0",
    "@tiptap/extension-highlight": "^3.0.0",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/extension-subscript": "^3.0.0",
    "@tiptap/extension-superscript": "^3.0.0",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/extension-table-header": "^3.0.0",
    "@tiptap/extension-table-of-contents": "^3.0.0",
    "@tiptap/extension-table-row": "^3.0.0",
    "@tiptap/extension-task-item": "^3.0.0",
    "@tiptap/extension-task-list": "^3.0.0",
    "@tiptap/extension-text-align": "^3.0.0",
    "@tiptap/extension-text-style": "^3.0.0",
    "@tiptap/extension-underline": "^3.0.0",
    "@tiptap/extension-unique-id": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@tiptap/vue-3": "^3.0.0",
    "ant-design-vue": "^4.0.0",
    "docx": "^9.0.0",
    "file-saver": "^2.0.0",
    "hotkeys-js": "^4.0.0",
    "katex": "^0.16.0",
    "linkifyjs": "^4.0.0",
    "lowlight": "^3.0.0",
    "mammoth": "^1.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tiptap/core": "^3.7.2",
    "@tiptap/extension-character-count": "^3.0.0",
    "@tiptap/extension-code-block-lowlight": "^3.7.1",
    "@tiptap/extension-color": "^3.0.0",
    "@tiptap/extension-font-family": "^3.7.2",
    "@tiptap/extension-highlight": "^3.0.0",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/extension-subscript": "^3.7.2",
    "@tiptap/extension-superscript": "^3.7.2",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/extension-table-header": "^3.13.0",
    "@tiptap/extension-table-of-contents": "^3.13.0",
    "@tiptap/extension-table-row": "^3.13.0",
    "@tiptap/extension-task-item": "^3.7.1",
    "@tiptap/extension-task-list": "^3.7.1",
    "@tiptap/extension-text-align": "^3.0.0",
    "@tiptap/extension-text-style": "^3.0.0",
    "@tiptap/extension-typography": "^3.7.2",
    "@tiptap/extension-underline": "^3.0.0",
    "@tiptap/extension-unique-id": "^3.13.0",
    "@tiptap/pm": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "@tiptap/vue-3": "^3.7.2",
    "@types/file-saver": "^2.0.7",
    "@types/katex": "^0.16.8",
    "@types/node": "^20.14.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "ant-design-vue": "^4.2.6",
    "docx": "^9.5.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.9.0",
    "file-saver": "^2.0.5",
    "globals": "^17.5.0",
    "hotkeys-js": "^4.0.4",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "katex": "^0.16.28",
    "linkifyjs": "^4.3.2",
    "lint-staged": "^16.4.0",
    "lowlight": "^3.3.0",
    "mammoth": "^1.11.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "rollup-plugin-obfuscator": "^1.1.0",
    "sass-embedded": "^1.96.0",
    "stylelint": "^17.9.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.0.0",
    "terser": "^5.44.1",
    "typescript": "~5.5.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^4.6.4",
    "vue-tsc": "2.0.26",
    "vue-types": "^3.0.2"
  },
  "keywords": [
    "tiptap",
    "tiptap3",
    "tiptap-editor",
    "tiptap-vue",
    "tiptap-template",
    "tiptap-appearance",
    "vue3",
    "vue",
    "vue-component",
    "vue-editor",
    "rich-text-editor",
    "wysiwyg",
    "wysiwyg-editor",
    "editor",
    "appearance",
    "ui-kit",
    "ai",
    "ai-editor",
    "ai-writing",
    "markdown",
    "prosemirror",
    "contenteditable",
    "text-editor",
    "word-processor",
    "notion",
    "notion-editor",
    "document-editor",
    "typescript",
    "dark-mode",
    "i18n",
    "cms"
  ],
  "author": "YanivWang",
  "homepage": "https://yanivwang.github.io/yaniv-editor/",
  "bugs": {
    "url": "https://github.com/YanivWang/yaniv-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YanivWang/yaniv-editor.git"
  },
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=10.17.0"
  }
}
