# tsc / vue-tsc 声明应只出现在 dist/；若仍出现在 src 则勿提交
src/**/*.d.ts
src/**/*.d.ts.map
!src/vite-env.d.ts

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-demo/
dist-ssr/
_site/
*.local

# VitePress (docs)
docs/.vitepress/cache/
docs/.vitepress/dist/

# Environment variables
.env
.env.local
.env.production
.env.*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output

# Lint / typecheck caches
.eslintcache
.stylelintcache
eslint-report.json
.pnpm-store/
*.tsbuildinfo

# Temporary files
*.tmp
*.temp
.cache/

# OS
Thumbs.db
.AppleDouble
.LSOverride

# Package manager
package-lock.json
yarn.lock

